{
  "name": "baileys-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for WhatsApp via @whiskeysockets/baileys",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "baileys-mcp": "dist/index.js"
  },
  "scripts": {
    "start": "node --experimental-sqlite dist/index.js",
    "dev": "tsx watch --experimental-sqlite src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=23"
  },
  "fnm": {
    "pin": "v24.11.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@whiskeysockets/baileys": "7.0.0-rc13",
    "qrcode": "^1.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/qrcode": "^1.5.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
